# SafeLink environment example
# Copy to .env and fill values.
# Recommended: run `npm run setup` for guided configuration.

# LLM Provider
# - anthropic
# - openai_compatible (OpenClaw gateway / OpenAI-compatible proxy)
LLM_PROVIDER=anthropic

# Anthropic mode
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI-compatible mode
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Wallet provider
# - auto (coinbase if CDP keys exist, else privy)
# - coinbase
# - privy
WALLET_PROVIDER=auto

# Coinbase AgentKit
COINBASE_CDP_API_KEY_NAME=
COINBASE_CDP_API_KEY_PRIVATE_KEY=
COINBASE_WALLET_DATA=

# Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=

# Base RPC
# Sepolia default:
BASE_RPC_URL=https://sepolia.base.org
# Mainnet option:
# BASE_RPC_URL=https://mainnet.base.org

# Mainnet safety gate (required when BASE_RPC_URL is mainnet)
MAINNET_ENABLED=false
MAINNET_CONFIRM_TEXT=
# For mainnet, set:
# MAINNET_ENABLED=true
# MAINNET_CONFIRM_TEXT=I_UNDERSTAND_MAINNET_RISK

# Contracts (set by deploy script)
ERC8004_REGISTRY_ADDRESS=
SAFE_ESCROW_ADDRESS=

# x402
X402_FACILITATOR_URL=https://x402.org/facilitator
# Optional: durable replay/idempotency store for multi-instance deploys
REDIS_URL=
REDIS_PREFIX=SafeLink

# Tenderly (optional)
TENDERLY_ACCESS_KEY=
TENDERLY_PROJECT_SLUG=SafeLink
TENDERLY_ACCOUNT_ID=

# Explorer (optional)
BASESCAN_API_KEY=

# Memory/storage
AUTONOMYS_NETWORK=taurus-testnet
AUTONOMYS_RPC_URL=

# Agent identity
AGENT_ID=
AGENT_NAME=my-SafeLink

# Task server
TASK_SERVER_PORT=3402
# Optional signed request authentication for /task endpoint
# If enabled, inbound requests must include:
# X-SafeLink-Timestamp, X-SafeLink-Nonce, X-SafeLink-Signature
TASK_AUTH_REQUIRED=false
TASK_AUTH_SHARED_SECRET=
TASK_AUTH_MAX_SKEW_SECONDS=300

# Optional SIWx assertion verification for inbound /task requests
SIWX_REQUIRED=false
SIWX_VERIFIER_URL=

# Runtime
NODE_ENV=development
LOG_LEVEL=info
RISK_APPROVAL_THRESHOLD=70
MIN_REPUTATION_SCORE=70


